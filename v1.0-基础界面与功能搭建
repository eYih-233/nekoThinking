// ���ش𰸿�
void MainWindow::loadAnswerLibrary()
{
    QString dataPath = QDir::currentPath() + "/data/answers.txt";

    // �����ǰĿ¼�Ҳ��������Կ�ִ���ļ�����Ŀ¼
    if (!QFile::exists(dataPath))
    {
        dataPath = QCoreApplication::applicationDirPath() + "/data/answers.txt";
    }

    if (m_answerData->loadAnswers(dataPath))
    {
        qDebug() << "Answer library loaded successfully, total" << m_answerData->getAnswerCount() << "answers";
    }
    else
    {
        // �������ʧ�ܣ�����һЩĬ�ϴ�
        m_answerData->addAnswer("Yes, definitely!");
        m_answerData->addAnswer("Think it over.");
        m_answerData->addAnswer("Don't rush, the time is not yet right.");
        m_answerData->addAnswer("Believe in yourself, you can do it!");
        m_answerData->addAnswer("Maybe look at it from a different angle.");
        qDebug() << "Failed to load answer library, using default answers";
    }
}

